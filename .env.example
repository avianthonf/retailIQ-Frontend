# Base origin for all /api/* and /oauth/* requests.
VITE_API_BASE_URL=

# OAuth base origin if the browser hosts authorize/token exchanges on a different origin.
VITE_OAUTH_BASE_URL=

# Socket.IO endpoint if the websocket server is not served from the same origin.
VITE_SOCKET_IO_URL=

# OAuth client identifier assigned to the developer application.
VITE_OAUTH_CLIENT_ID=

# Redirect URI registered for authorization-code flows.
VITE_OAUTH_REDIRECT_URI=

# Payment provider publishable key, only needed if a browser SDK is added.
VITE_PAYMENT_PUBLISHABLE_KEY=
